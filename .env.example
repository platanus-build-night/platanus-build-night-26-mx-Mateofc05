# LineUp environment example — copy to .env and fill in real values.

# --- Database (Railway Postgres) ---
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- S3-compatible object storage (Railway bucket, private) ---
S3_ENDPOINT=https://your-bucket-endpoint.example.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1

# --- Generation (optional) ---
# Default deterministic templates. Set to "true" to use a real LLM
# (falls back to templates automatically on any error).
USE_LLM=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email (optional) ---
# Without a key, sends are mocked.
RESEND_API_KEY=
